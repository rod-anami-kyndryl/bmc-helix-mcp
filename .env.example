# BMC Helix ITSM Configuration
HELIX_API_URL=https://your-helix-instance.onbmc.com/api/arsys/v1/entry/
HELIX_TOKEN_URL=https://your-helix-instance.onbmc.com/api/jwt/login
HELIX_USERID=your_username
HELIX_PASSWORD=your_password

# MCP Server Configuration
MCP_PORT=4044
MCP_AUTH_TOKEN=your_mcp_secret_token

# TLS / HTTPS Configuration
MCP_TLS_ENABLED=true
MCP_TLS_KEY=./certs/mcp-server.key
MCP_TLS_CERT=./certs/mcp-server.crt
MCP_TLS_CA=./certs/ca.crt
